{
  "$schema": "https://opencode.ai/config.json",
  "model": "lmstudio/gemma4",
  "provider": {
    "ollama": {
      "models": {
        "gemma4": {
          "name": "gemma4"
        }
      },
      "name": "LM Studio",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    }
  },
  "agent": {
    "plan": {
      "model": "github-copilot/gpt-5.4",
      "reasoningEffort": "high",
      "permission": {
        "bash": {
          "*": "ask",
          "gh repo view*": "allow",
          "gh api*": "allow",
          "gh search*": "allow",
          "gh issue*": "allow",
          "gh pr list*": "allow",
          "gh pr view*": "allow",
          "gh pr diff*": "allow",
          "gh project item-add*": "allow",
          "gh auth status*": "allow"
        }
      }
    },
    "build": {
      "model": "github-copilot/claude-sonnet-4.6",
      "reasoningEffort": "high"
    }
  },
  "permission": {
    "external_directory": {
      "~/github/glg/**": "allow",
      "~/github/glg/epiquery-templates/**": "allow",
      "~/github/mhuggins7278/notes/**": "allow",
      "~/.config/opencode/references/**": "allow",
      "~/.dotfiles/config/opencode/references/**": "allow",
      "~/zoom-transcripts/**": "allow"
    },
    "skill": {
      "*": "allow"
    }
  },
  "mcp": {
    "whoIs": {
      "type": "local",
      "command": ["npx", "-y", "@glg/mcp-whois"],
      "enabled": true
    },
    "gdsData": {
      "type": "local",
      "command": ["npx", "-y", "@glg/mcp-gds"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  },
  "tools": {
    "figma*": false,
    "gdsData_*": false,
    "whoIs_*": false,
    "playwright_*": false,
    "context7_*": false
  }
}
