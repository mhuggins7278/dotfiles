<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.kanata.agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>{% if ansible_machine == 'arm64' %}/opt/homebrew/bin/kanata{% else %}/usr/local/bin/kanata{% endif %}</string>
    <string>-c</string>
    <string>{{ ansible_env.HOME }}/.dotfiles/config/kanata/moonlander.kbd</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/kanata.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/kanata.err</string>
</dict>
</plist>
