#!/usr/bin/env bash
# agent-review — Spawn an opencode review session for a GitHub PR
# Usage: agent-review <pr_number> <repo_name> <repo_path>
#
# Fixes vs the inline tmux new-window approach:
#   - Creates a dedicated named tmux session via sesh (not just a new window)
#   - Pulls latest when the worktree already exists
#   - Gracefully handles PRs where the source branch is the repo's default
#     branch (e.g. test→main), where wt cannot create a separate worktree

set -euo pipefail

PR_NUM="$1"
REPO_NAME="$2"
REPO_PATH="$3"

# Ensure the repo is cloned locally under ~/github/{org}/{repo}
OWNER="${REPO_NAME%%/*}"
REPO="${REPO_NAME##*/}"
CANONICAL_REPO_PATH="$HOME/github/$OWNER/$REPO"

if git -C "$REPO_PATH" rev-parse --show-toplevel >/dev/null 2>&1; then
  REPO_PATH="$REPO_PATH"
else
  REPO_PATH="$CANONICAL_REPO_PATH"

  if ! git -C "$REPO_PATH" rev-parse --show-toplevel >/dev/null 2>&1; then
    if [ -e "$REPO_PATH" ]; then
      echo "[agent-review] path exists but is not a git repo: $REPO_PATH" >&2
      exit 1
    fi

    mkdir -p "$HOME/github/$OWNER"
    gh repo clone "$REPO_NAME" "$REPO_PATH"
  fi
fi

# Resolve PR branch name
BRANCH=$(gh pr view "$PR_NUM" -R "$REPO_NAME" --json headRefName -q '.headRefName')

# Detect the repo's default branch — wt refuses to create a secondary worktree
# for the default branch since the primary checkout already serves that role.
DEFAULT_BRANCH=$(git -C "$REPO_PATH" config --get worktrunk.default-branch 2>/dev/null \
  || git -C "$REPO_PATH" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | cut -d/ -f2 \
  || echo "main")

if [ "$BRANCH" = "$DEFAULT_BRANCH" ]; then
  # PR branch is the default branch — use the main checkout directly
  WT_PATH="$REPO_PATH"
  IS_DEFAULT_BRANCH=true
else
  # Create worktree (or switch to existing) via wt
  wt -C "$REPO_PATH" switch "pr:$PR_NUM" --no-cd

  # Get authoritative worktree path from git
  WT_PATH=$(git -C "$REPO_PATH" worktree list --porcelain \
    | awk -v branch="refs/heads/$BRANCH" '
        /^worktree / { path = substr($0, 10) }
        $0 == "branch " branch { print path; exit }
      ')
  IS_DEFAULT_BRANCH=false
fi

# Session name = basename of worktree path (matches sesh naming convention)
SESSION_NAME=$(basename "$WT_PATH")

# Detect dependency install command (read lockfiles before entering session)
INSTALL_CMD=""
if [ -f "$WT_PATH/pnpm-lock.yaml" ]; then
  INSTALL_CMD="pnpm install"
elif [ -f "$WT_PATH/yarn.lock" ]; then
  INSTALL_CMD="yarn install"
elif [ -f "$WT_PATH/package-lock.json" ]; then
  INSTALL_CMD="npm ci"
elif [ -f "$WT_PATH/package.json" ]; then
  INSTALL_CMD="npm install"
elif [ -f "$WT_PATH/Gemfile.lock" ]; then
  INSTALL_CMD="bundle install"
elif [ -f "$WT_PATH/requirements.txt" ]; then
  INSTALL_CMD="pip install -r requirements.txt"
elif [ -f "$WT_PATH/go.mod" ]; then
  INSTALL_CMD="go mod download"
elif [ -f "$WT_PATH/Cargo.toml" ]; then
  INSTALL_CMD="cargo fetch"
fi

# Cleanup: skip wt remove when reviewing the primary checkout
if [ "$IS_DEFAULT_BRANCH" = "true" ]; then
  CLEANUP="tmux kill-session -t '${SESSION_NAME}'"
else
  CLEANUP="wt remove --no-delete-branch --force -y 2>/dev/null ; tmux kill-session"
fi

# Build startup: git sync + install (if needed) + opencode + cleanup
# Use fetch + reset instead of pull to handle diverged branches gracefully.
FNM_SETUP='eval "$(fnm env --shell bash)" && fnm use --install-if-missing'

STARTUP="git -C '$WT_PATH' fetch origin '$BRANCH' && git -C '$WT_PATH' reset --hard 'origin/$BRANCH'"
if [ -n "$INSTALL_CMD" ]; then
  if [[ "$INSTALL_CMD" =~ ^(pnpm|yarn|npm) ]]; then
    STARTUP="$STARTUP && (cd '$WT_PATH' && $FNM_SETUP && $INSTALL_CMD)"
  else
    STARTUP="$STARTUP && (cd '$WT_PATH' && $INSTALL_CMD)"
  fi
fi
STARTUP="$STARTUP && opencode --agent review --prompt 'Review PR #${PR_NUM} in ${REPO_NAME}.' ; ${CLEANUP}"

# Create/connect to named session (sesh handles the client switch internally)
sesh connect --command "$STARTUP" "$WT_PATH"
